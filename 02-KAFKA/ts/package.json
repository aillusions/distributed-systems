{
  "name": "kafka-lab-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Produce/consume against a 3-broker KRaft Kafka cluster; drive durability, queue, and streaming drills while exporting metrics to Grafana.",
  "scripts": {
    "smoke": "tsx src/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
